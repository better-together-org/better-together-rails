#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

# shellcheck source=./docker-compose-env.sh
source "$repo_root/bin/docker-compose-env.sh"

if [[ -z "${BTR_WORKTREE_DB_SUFFIX:-}" ]]; then
  exit 0
fi

primary_test_db="better_together_test${BTR_WORKTREE_DB_SUFFIX}"

db_has_required_test_schema() {
  local database_name="$1"
  local result
  result="$(docker exec community-engine-db psql -U postgres -d "$database_name" -tAc \
    "SELECT
       to_regclass('public.ar_internal_metadata') IS NOT NULL
       AND EXISTS (
         SELECT 1
         FROM ar_internal_metadata
         WHERE key = 'environment' AND value = 'test'
       );" 2>/dev/null || true)"
  [[ "$result" == "t" ]]
}

if docker exec community-engine-db psql -U postgres -tAc \
  "SELECT 1 FROM pg_database WHERE datname='${primary_test_db}'" | grep -q 1; then
  if db_has_required_test_schema "$primary_test_db"; then
    exit 0
  fi

  echo "Rebuilding incomplete worktree test DB ${primary_test_db}..."
  docker exec community-engine-db psql -U postgres -d postgres -v ON_ERROR_STOP=1 \
    -c "DROP DATABASE IF EXISTS \"${primary_test_db}\" WITH (FORCE);" >/dev/null
fi

echo "Preparing worktree test database for suffix ${BTR_WORKTREE_DB_SUFFIX}..."
./bin/dc run --rm --no-deps app env RAILS_ENV=test bundle exec rails \
  db:drop db:create db:schema:load db:environment:set
